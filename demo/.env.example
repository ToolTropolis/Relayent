# Relayent Demo — copy to .env, fill in, keep OUT of git.

# The relay's base URL. On the shared docker network this is the container name;
# override if the demo runs elsewhere.
DEMO_RELAY_URL=http://relayent-relay:8787

# App credential "<id>.<secret>" — issue one in the admin console (App credentials)
# or via POST /v1/admin/app-creds. Server-side only.
#
# For the admin "Demo visitors" analytics to record hits, this credential also
# needs the "demo-stats" scope. Issue it with:
#   POST /v1/admin/app-creds  {"app_id":"demo","scopes":["enqueue","demo-stats"]}
# ("enqueue" runs chat jobs; "demo-stats" writes content-free visitor hits.)
DEMO_APP_CREDENTIAL=

# Whose bridge/subscription runs the jobs (an OIDC subject or user id). The demo
# routes every message to this user; that user must have a bridge online.
DEMO_TARGET_USER=

# Which backend is pre-selected. Keep this to one you're happy for the public to
# spend — and make sure paid backends are DISABLED in the relay admin console.
DEMO_DEFAULT_BACKEND=cursor

# Page title / heading.
DEMO_TITLE=Relayent Playground

# Visitor analytics (admin-only, shown in the relay's "Demo visitors" tab).
# Set to 1 ONLY when the demo runs behind a trusted reverse proxy, so the real
# visitor IP is read from X-Forwarded-For (for country/uniques). Leave unset for
# a directly-exposed demo — otherwise a caller could spoof the header.
# DEMO_TRUST_PROXY=1
