# Relayent relay deployment configuration.
#
# Copy to .env and fill in. NEVER commit .env — it holds your pairing key, which
# is the only thing standing between the internet and your CLI subscription.
#
#   cp .env.example .env

# The domain this relay will serve. Its A/AAAA record must already point at this
# host, and ports 80/443 must be reachable, or Let's Encrypt cannot issue a cert.
RELAYENT_DOMAIN=relay.example.com

# Contact address for Let's Encrypt (expiry warnings). Optional but recommended.
ACME_EMAIL=you@example.com

# The pairing key. Generate one — do not invent one:
#
#   docker compose run --rm relay keygen
#
# During a rotation, list both: "newkey,oldkey". The first is primary; the rest
# still work until you drop them. See: relayent-relay rotate
RELAYENT_PAIRING_KEY=
