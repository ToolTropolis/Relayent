# Relayent relay — behind-an-existing-proxy deployment.
# Copy to .env in deploy/, fill in, and keep it OUT of git.

# Legacy pairing key — keeps an existing single-key integration working during
# migration. Generate: docker run --rm relayent-relay:latest keygen
# Optional; omit for a fresh multi-tenant-only deployment.
RELAYENT_PAIRING_KEY=

# Bootstrap admin token — grants admin scope (mint enroll tokens + app creds,
# view activity, use the /admin dashboard). >=24 chars. Generate with keygen.
# Remove once a real OIDC admin exists.
RELAYENT_ADMIN_TOKEN=

# Session signing key — the HMAC key for admin session cookies. SET THIS: if it
# is blank the relay picks a new random key each time the process starts, so
# every restart or redeploy invalidates all sessions and logs everyone out.
# Any stable secret >=16 chars (32+ recommended). Generate:
#   head -c 36 /dev/urandom | base64
RELAYENT_SESSION_KEY=

# OIDC (optional; leave blank until the live Google flow is verified).
RELAYENT_OIDC_ISSUER=
RELAYENT_OIDC_CLIENT_ID=
RELAYENT_OIDC_CLIENT_SECRET=
RELAYENT_OIDC_REDIRECT_URL=
RELAYENT_OIDC_HOSTED_DOMAIN=
